{
  "name": "ensembl-new",
  "version": "0.0.1",
  "description": "New website of Ensembl",
  "main": "index.js",
  "directories": {
    "example": "example"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "EMBL-EBI",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "prestart": "npm install --no-save",
    "start": "NODE_ENV=development TS_NODE_PROJECT=tsconfig.tooling.json ts-node --transpile-only scripts/start",
    "prebuild": "rimraf ./dist",
    "build": "NODE_ENV=production TS_NODE_PROJECT=tsconfig.tooling.json ts-node --transpile-only scripts/build",
    "prod:analyse": "NODE_ENV=production TS_NODE_PROJECT=tsconfig.tooling.json ts-node --transpile-only scripts/analyzeClient",
    "lint": "npm run lint:scripts && npm run lint:styles",
    "lint:scripts": "eslint 'src/**/*.{ts,tsx}'",
    "lint:styles": "stylelint 'src/**/*.css'",
    "storybook": "storybook dev -p 9001 -c .storybook",
    "deploy-docs": "./deploy-docs.sh",
    "check-types": "tsc",
    "test": "npm run test-node && npm run test-browser",
    "test-node": "vitest run",
    "test-node:watch": "vitest",
    "test-coverage-node": "vitest run --coverage",
    "test-browser": "vitest run --config ./vitest.config.browser.mts",
    "test-browser:watch": "vitest --config ./vitest.config.browser.mts",
    "test-coverage-browser": "vitest run --config ./vitest.config.browser.mts --coverage"
  },
  "dependencies": {
    "@ensembl/ensembl-elements-common": "0.0.5",
    "@ensembl/ensembl-genome-browser": "0.6.14",
    "@ensembl/ensembl-structural-variants": "0.0.11",
    "@reduxjs/toolkit": "2.12.0",
    "@sentry/browser": "10.66.0",
    "classnames": "2.5.1",
    "comlink": "4.4.2",
    "core-js": "3.49.0",
    "d3": "7.9.0",
    "express": "5.2.1",
    "filesize": "11.0.22",
    "graphql": "16.14.2",
    "graphql-request": "6.1.0",
    "http-proxy-middleware": "4.2.0",
    "idb": "8.0.3",
    "jszip": "3.10.1",
    "lit": "3.3.3",
    "lodash": "4.18.1",
    "morgan": "1.11.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-redux": "9.3.0",
    "react-router": "7.17.0",
    "react-router-dom": "7.17.0",
    "redux": "5.0.1",
    "redux-observable": "3.0.0-rc.3",
    "redux-thunk": "3.1.0",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/plugin-transform-modules-commonjs": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "8.0.1",
    "@eslint/js": "9.39.2",
    "@faker-js/faker": "10.5.0",
    "@storybook/addon-webpack5-compiler-babel": "4.0.1",
    "@storybook/react-webpack5": "10.5.2",
    "@svgr/webpack": "8.1.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/d3": "7.4.3",
    "@types/express": "5.0.6",
    "@types/lodash": "4.17.24",
    "@types/morgan": "1.9.10",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-redux": "7.1.34",
    "@types/react-router-dom": "5.3.3",
    "@types/webpack-env": "1.18.8",
    "@types/webpack-hot-middleware": "2.25.12",
    "@types/webpack-node-externals": "3.0.4",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/eslint-plugin": "1.6.20",
    "babel-loader": "10.1.1",
    "babel-plugin-react-remove-properties": "0.3.1",
    "compression-webpack-plugin": "12.0.0",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "css-minimizer-webpack-plugin": "8.0.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "fake-indexeddb": "6.2.5",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "gh-pages": "6.3.0",
    "husky": "9.1.7",
    "identity-obj-proxy": "3.0.0",
    "jsdom": "29.1.1",
    "licence-manager": "git+https://github.com/Ensembl/ensembl-licence-manager.git#36b534d28ff26d345b4ba4da0cbc18e1e0f7a6b7",
    "lint-staged": "17.1.0",
    "mini-css-extract-plugin": "2.10.2",
    "msw": "2.15.0",
    "nodemon": "3.1.14",
    "postcss": "8.5.20",
    "postcss-loader": "8.2.1",
    "postcss-preset-env": "11.3.2",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "source-map-loader": "5.0.0",
    "storybook": "10.5.2",
    "style-loader": "4.0.0",
    "stylelint": "17.14.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-webpack-plugin": "5.1.0",
    "terser-webpack-plugin": "5.6.1",
    "ts-multipick": "1.0.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.9",
    "vitest-browser-react": "2.2.0",
    "webpack": "5.108.4",
    "webpack-bundle-analyzer": "5.3.1",
    "webpack-cli": "7.2.1",
    "webpack-dev-middleware": "8.0.3",
    "webpack-dev-server": "6.0.0",
    "webpack-manifest-plugin": "6.0.1",
    "webpack-merge": "6.0.1",
    "webpack-node-externals": "3.0.0",
    "workbox-webpack-plugin": "7.4.1"
  },
  "overrides": {
    "msw": {
      "typescript": "$typescript"
    },
    "storybook": "$storybook"
  },
  "browserslist": [
    "> 1% and last 2 versions",
    "not dead",
    "not ie 11",
    "not op_mini all"
  ]
}
